<?xml version="1.0"?>
<robot name="vehicle_blue">
  <!-- ================= ROOT FRAME ================= -->
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <inertial>
      <mass value="5.0"/>
      <inertia
        ixx="0.2" ixy="0.0" ixz="0.0"
        iyy="0.2" iyz="0.0"
        izz="0.2"/>
    </inertial>
    <!-- Box height = 0.2 → lift 0.1 so bottom sits at z=0 -->
    <visual>
      <origin xyz="0 0 0.1"/>
      <geometry>
        <box size="0.7 0.3 0.2"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1"/>
      <geometry>
        <box size="0.7 0.3 0.2"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= FRONT LEFT WHEEL ================= -->
  <link name="front_left_wheel">
    <inertial>
      <mass value="0.5"/>
      <inertia
        ixx="0.001" ixy="0.0" ixz="0.0"
        iyy="0.001" iyz="0.0"
        izz="0.0005"/>
    </inertial>
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.10"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.10"/>
      </geometry>
    </collision>
  </link>
  <!-- x=0.25  : near front of body (half-length=0.35)          -->
  <!-- y=+0.175: wheel face clears body side (half-width=0.15)   -->
  <!-- z=0.10  : wheel radius → bottom of wheel touches ground   -->
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.25 0.175 0.10"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= FRONT RIGHT WHEEL ================= -->
  <link name="front_right_wheel">
    <inertial>
      <mass value="0.5"/>
      <inertia
        ixx="0.001" ixy="0.0" ixz="0.0"
        iyy="0.001" iyz="0.0"
        izz="0.0005"/>
    </inertial>
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.10"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.10"/>
      </geometry>
    </collision>
  </link>
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.25 -0.175 0.10"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= REAR CASTER ================= -->
  <link name="caster_wheel">
    <inertial>
      <mass value="0.2"/>
      <inertia
        ixx="0.001" ixy="0.0" ixz="0.0"
        iyy="0.001" iyz="0.0"
        izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <sphere radius="0.10"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.10"/>
      </geometry>
    </collision>
  </link>
  <!-- x=-0.25 : inset from rear edge (half-length=0.35), was -0.35 which placed it outside the body -->
  <!-- z=0.10  : sphere radius → bottom of sphere touches ground                                     -->
  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="-0.25 0 0.10"/>
  </joint>

  <!-- ================= DIFF DRIVE ================= -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <!-- wheel_separation matches joint y-offsets: 0.175 * 2 = 0.35 -->
      <wheel_separation>0.35</wheel_separation>
      <wheel_radius>0.10</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
    </plugin>
  </gazebo>
</robot>